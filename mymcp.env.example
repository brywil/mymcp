# mymcp serve configuration (copied to ~/.config/mymcp/mymcp.env by
# `task install-unit`). Edit, then: systemctl --user start mymcp

# Address mymcp listens on (mTLS). Use 0.0.0.0 to accept LAN clients.
ADDR=0.0.0.0:9443

# Root directory the filesystem tools are confined to (and where run_command
# executes). Must be an ABSOLUTE path — systemd env files do not expand ~ or
# $HOME. `task install-unit` fills this in with $HOME/mymcp-workspace for you.
WORKSPACE=/home/you/mymcp-workspace

# To trust a client CA, drop its PEM into ~/.config/mymcp/trust/authorities/.
# Grant a principal: mymcp allow "<cert CN>" <tool|ro|all>
