# mymcp serve configuration (copied to ~/.config/mymcp/mymcp.env by
# `task install-unit`). Edit, then: systemctl --user start mymcp

# Listen address. Loopback only — mymcp is unauthenticated-by-network and
# local-only; for LAN/remote, keep this on loopback and front it with truemtls.
ADDR=127.0.0.1:9443

# Root directory the filesystem tools are confined to (and where run_command
# executes). Must be an ABSOLUTE path — systemd env files don't expand ~/$HOME.
# `task install-unit` fills this in with $HOME/mymcp-workspace for you.
WORKSPACE=/home/you/mymcp-workspace

# Auth: serve requires a bearer token, auto-generated at ~/.config/mymcp/token.
# Retrieve it for your MCP client's Authorization header with:  mymcp token
